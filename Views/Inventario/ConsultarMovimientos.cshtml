@{
    ViewData["Title"] = "Consultar Movimientos";
    ViewData["NavActive"] = "inventario";
}

<div class="main-content">
    <div class="flex-between mb-2">
        <h1 class="page-title">Consultar movimientos</h1>
        <div class="search-bar">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="text" placeholder="Buscar producto..." />
        </div>
    </div>

    <div class="card card-gold mb-2">
        <div class="flex gap-3 mb-2" style="flex-wrap:wrap">
            <div>
                <label class="text-muted" style="font-size:12px;display:block;margin-bottom:4px">Tipo</label>
                <select class="form-control" style="max-width:140px">
                    <option>Todos</option>
                    <option>Entradas</option>
                    <option>Salidas</option>
                </select>
            </div>
            <div>
                <label class="text-muted" style="font-size:12px;display:block;margin-bottom:4px">Desde</label>
                <input class="form-control" type="date" value="2025-10-01" style="max-width:160px"/>
            </div>
            <div>
                <label class="text-muted" style="font-size:12px;display:block;margin-bottom:4px">Hasta</label>
                <input class="form-control" type="date" value="2025-10-26" style="max-width:160px"/>
            </div>
            <div style="align-self:flex-end">
                <button class="btn btn-gold" onclick="showModal('modalSinMovimientos')">Filtrar</button>
            </div>
        </div>
    </div>

    <div class="card">
        <table style="width:100%;border-collapse:collapse;font-size:13px">
            <thead>
                <tr style="border-bottom:1px solid #3a3a3a;color:var(--text-muted)">
                    <th style="padding:10px;text-align:left">Fecha</th>
                    <th style="padding:10px;text-align:left">Producto</th>
                    <th style="padding:10px;text-align:left">Código</th>
                    <th style="padding:10px;text-align:left">Tipo</th>
                    <th style="padding:10px;text-align:left">Cantidad</th>
                    <th style="padding:10px;text-align:left">Usuario</th>
                </tr>
            </thead>
            <tbody>
                <tr style="border-bottom:1px solid #3a3a3a">
                    <td style="padding:10px">26/10/2025</td>
                    <td style="padding:10px">Ron Barceló</td>
                    <td style="padding:10px;color:var(--gold)">5678-RB</td>
                    <td style="padding:10px"><span style="background:rgba(76,175,125,0.2);color:#4caf7d;padding:2px 10px;border-radius:12px">Entrada</span></td>
                    <td style="padding:10px">15</td>
                    <td style="padding:10px">Juan Pérez</td>
                </tr>
                <tr style="border-bottom:1px solid #3a3a3a">
                    <td style="padding:10px">25/10/2025</td>
                    <td style="padding:10px">Tequila Don Julio</td>
                    <td style="padding:10px;color:var(--gold)">TDJ-70-75</td>
                    <td style="padding:10px"><span style="background:rgba(224,82,82,0.2);color:#e05252;padding:2px 10px;border-radius:12px">Salida</span></td>
                    <td style="padding:10px">54</td>
                    <td style="padding:10px">Camilo Alonso</td>
                </tr>
                <tr>
                    <td style="padding:10px">24/10/2025</td>
                    <td style="padding:10px">Cerveza Corona</td>
                    <td style="padding:10px;color:var(--gold)">CC-150</td>
                    <td style="padding:10px"><span style="background:rgba(76,175,125,0.2);color:#4caf7d;padding:2px 10px;border-radius:12px">Entrada</span></td>
                    <td style="padding:10px">150</td>
                    <td style="padding:10px">Juan Pérez</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal-overlay" id="modalSinMovimientos">
    <div class="modal-box">
        <div class="modal-brand">
            <svg width="20" height="20" viewBox="0 0 44 44"><circle cx="22" cy="22" r="20" fill="#2c2c2c" stroke="#D4A017" stroke-width="2"/><text x="22" y="27" text-anchor="middle" font-size="14" font-weight="bold" fill="#D4A017" font-family="serif">G</text></svg>
            Gold Club
        </div>
        <div class="modal-message">No existen movimientos con los filtros seleccionados.</div>
        <div class="modal-actions">
            <button class="btn btn-gold" onclick="hideModal('modalSinMovimientos')">✔ Aceptar</button>
        </div>
    </div>
</div>
