@{
    ViewData["Title"] = "Verificar Documentos";
    ViewData["NavActive"] = "inventario";
}

<div class="main-content">
    <h1 class="page-title">Verificar documentos</h1>

    <div class="card card-gold">
        <div class="flex-between mb-2">
            <span style="font-weight:600">Documentos pendientes de verificación</span>
            <div class="search-bar">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                <input type="text" placeholder="Buscar..." />
            </div>
        </div>

        <table style="width:100%;border-collapse:collapse;font-size:13px">
            <thead>
                <tr style="border-bottom:1px solid #3a3a3a;color:var(--text-muted)">
                    <th style="padding:10px;text-align:left">N.° Documento</th>
                    <th style="padding:10px;text-align:left">Tipo</th>
                    <th style="padding:10px;text-align:left">Fecha</th>
                    <th style="padding:10px;text-align:left">Estado</th>
                    <th style="padding:10px;text-align:left">Acción</th>
                </tr>
            </thead>
            <tbody>
                <tr style="border-bottom:1px solid #3a3a3a">
                    <td style="padding:10px;color:var(--gold)">#DESP-0012</td>
                    <td style="padding:10px">Nota de despacho</td>
                    <td style="padding:10px">26/10/2025</td>
                    <td style="padding:10px"><span style="background:rgba(212,160,23,0.2);color:var(--gold);padding:2px 10px;border-radius:12px">Pendiente</span></td>
                    <td style="padding:10px"><a class="btn btn-gold" style="padding:4px 14px;font-size:12px" href="/Documentos/NotaDespacho">Ver</a></td>
                </tr>
                <tr style="border-bottom:1px solid #3a3a3a">
                    <td style="padding:10px;color:var(--gold)">#INC-2025-0045</td>
                    <td style="padding:10px">Reporte incidentes</td>
                    <td style="padding:10px">25/10/2025</td>
                    <td style="padding:10px"><span style="background:rgba(224,82,82,0.2);color:#e05252;padding:2px 10px;border-radius:12px">Revisión</span></td>
                    <td style="padding:10px"><a class="btn btn-gold" style="padding:4px 14px;font-size:12px" href="/Documentos/ReporteIncidentes">Ver</a></td>
                </tr>
                <tr>
                    <td style="padding:10px;color:var(--gold)">#ORD-PREP-24</td>
                    <td style="padding:10px">Orden preparación</td>
                    <td style="padding:10px">24/10/2025</td>
                    <td style="padding:10px"><span style="background:rgba(76,175,125,0.2);color:#4caf7d;padding:2px 10px;border-radius:12px">Verificado</span></td>
                    <td style="padding:10px"><a class="btn btn-gold" style="padding:4px 14px;font-size:12px" href="/Documentos/OrdenPreparacion">Ver</a></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
