@{
    ViewData["Title"] = "Registrar Salida";
    ViewData["NavActive"] = "inventario";
}

<div class="main-content">
    <h1 class="page-title">Registrar salida de producto</h1>

    <div class="card card-gold" style="max-width:680px">
        <div class="form-group">
            <label>Código del producto:</label>
            <input class="form-control" type="text" placeholder="Ej: 5678-RB" />
        </div>
        <div class="form-group">
            <label>Cantidad a retirar:</label>
            <input class="form-control" type="number" placeholder="0" />
        </div>
        <div class="form-group">
            <label>Motivo de salida:</label>
            <input class="form-control" type="text" placeholder="Ej: Venta, caducidad..." />
        </div>
        <div class="form-group">
            <label>Fecha:</label>
            <input class="form-control" type="date" value="2025-10-26" />
        </div>
        <div class="form-group">
            <label>Registrado por:</label>
            <input class="form-control" type="text" value="Juan Pérez" readonly />
        </div>

        <div class="mt-3 text-center">
            <button class="btn btn-gold" onclick="showModal('modalSalidaOk')">Confirmar salida</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="modalSalidaOk">
    <div class="modal-box">
        <div class="modal-brand">
            <svg width="20" height="20" viewBox="0 0 44 44"><circle cx="22" cy="22" r="20" fill="#2c2c2c" stroke="#D4A017" stroke-width="2"/><text x="22" y="27" text-anchor="middle" font-size="14" font-weight="bold" fill="#D4A017" font-family="serif">G</text></svg>
            Gold Club
        </div>
        <div class="modal-message">Salida registrada con éxito.</div>
        <div class="modal-actions">
            <a class="btn btn-gold" href="/Home/Dashboard">✔ Aceptar</a>
        </div>
    </div>
</div>
