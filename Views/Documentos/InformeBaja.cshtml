@{
    ViewData["Title"] = "Informe de Baja";
    ViewData["NavActive"] = "documentos";
}

<div class="main-content">
    <div class="card card-gold" style="max-width:680px">
        <div class="section-heading" style="margin-top:0">Informe de baja</div>

        <div class="form-group">
            <label>Código del producto:</label>
            <input class="form-control" type="text" value="14839987325" />
        </div>
        <div class="form-group">
            <label>Motivo de baja:</label>
            <input class="form-control" type="text" value="Producto vencido" />
        </div>
        <div class="form-group">
            <label>Cantidad de producto:</label>
            <input class="form-control" type="number" value="10" />
        </div>
        <div class="form-group">
            <label>Fecha:</label>
            <input class="form-control" type="text" value="26/10/2025" />
        </div>

        <div class="section-heading">Firma del encargado del almacén</div>
        <div class="form-group">
            <label>Firma encargado:</label>
            <input class="form-control" type="text" value="Usuario: Joselito Pérez - Firma electrónica" readonly />
        </div>

        <div class="mt-3 text-center">
            <button class="btn btn-gold" onclick="showModal('modalBajaOk')">Generar informe de baja</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="modalBajaOk">
    <div class="modal-box">
        <div class="modal-brand">
            <svg width="20" height="20" viewBox="0 0 44 44"><circle cx="22" cy="22" r="20" fill="#2c2c2c" stroke="#D4A017" stroke-width="2"/><text x="22" y="27" text-anchor="middle" font-size="14" font-weight="bold" fill="#D4A017" font-family="serif">G</text></svg>
            Gold Club
        </div>
        <div class="modal-message">Informe de baja generado con éxito.</div>
        <div class="modal-actions">
            <a class="btn btn-gold" href="/Documentos/Index">✔ Aceptar</a>
        </div>
    </div>
</div>
