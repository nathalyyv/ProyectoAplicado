@{
    ViewData["Title"] = "Documentos Digitalizados";
    ViewData["NavActive"] = "documentos";
}

<div class="main-content">
    <h1 class="page-title">Documentos Digitalizados</h1>

    <div class="card">
        <div class="flex-between mb-3">
            <span style="font-size:16px;font-weight:600">Inventario / almacén</span>
            <div class="flex gap-2">
                <div class="search-bar">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                    <input type="text" placeholder="Buscar" />
                </div>
                <button class="btn btn-gold">Subir nuevo documento</button>
            </div>
        </div>

        <div class="doc-grid">
            <a class="doc-card" href="/Documentos/NotaDespacho">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M9 11H5a2 2 0 00-2 2v5a2 2 0 002 2h14a2 2 0 002-2v-5a2 2 0 00-2-2h-4M9 11V7a3 3 0 116 0v4M9 11h6"/>
                </svg>
                <span class="doc-card-label">Nota de despacho</span>
            </a>

            <a class="doc-card" href="/Documentos/ReporteIncidentes">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <circle cx="12" cy="14" r="1"/><line x1="12" y1="11" x2="12" y2="11.5"/>
                </svg>
                <span class="doc-card-label">Reporte de incidentes</span>
            </a>

            <a class="doc-card" href="/Documentos/OrdenPreparacion">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                    <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
                </svg>
                <span class="doc-card-label">Orden de preparación</span>
            </a>

            <a class="doc-card" href="/Documentos/InformeBaja">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="12" y1="18" x2="12" y2="12"/>
                    <line x1="9" y1="15" x2="15" y2="15"/>
                </svg>
                <span class="doc-card-label">Informe de baja</span>
            </a>
        </div>
    </div>
</div>
