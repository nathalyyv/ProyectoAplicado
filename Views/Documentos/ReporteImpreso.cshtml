@{
    ViewData["Title"] = "Reporte Impreso";
    ViewData["NavActive"] = "documentos";
}

<div class="main-content">
    <div class="two-col">
        <div style="background:#c8c8c8;border-radius:12px;padding:28px;color:#1a1a1a">
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px">
                <svg width="50" height="50" viewBox="0 0 80 80">
                    <circle cx="40" cy="40" r="38" fill="#2c2c2c" stroke="#D4A017" stroke-width="3"/>
                    <text x="40" y="50" text-anchor="middle" font-size="28" font-weight="bold" fill="#D4A017" font-family="serif">G</text>
                </svg>
                <span style="font-size:20px;font-weight:700">Gold Club Tenares</span>
            </div>

            <h2 style="font-size:20px;font-weight:700;margin-bottom:16px">Reporte de incidentes</h2>

            <div style="background:white;border-radius:8px;padding:16px;margin-bottom:16px">
                <div style="font-weight:700;margin-bottom:10px;font-size:14px">Fecha de incidente</div>

                @foreach (var field in new[] {
                    ("Fecha de guía:", "26/10/2025"),
                    ("Número de guía:", "GIA-2025-0123"),
                    ("Código de producto:", "Cód: 5678- Ron añejo"),
                    ("Cantidad de producto:", "5"),
                    ("Cantidad de faltante:", "Cód: 5678-Ron añejo")
                })
                {
                    <div style="display:flex;gap:12px;margin-bottom:8px;font-size:13px">
                        <span style="min-width:180px;color:#555">@field.Item1</span>
                        <span style="background:#e8e8e8;border-radius:4px;padding:3px 10px;flex:1">@field.Item2</span>
                    </div>
                }
            </div>

            <div style="background:white;border-radius:8px;padding:16px;margin-bottom:16px">
                <div style="font-weight:700;margin-bottom:8px;font-size:14px">Descripción del problema</div>
                <div style="background:#e8e8e8;border-radius:4px;padding:10px;font-size:13px">
                    Cinco botellas de ron añejo dañadas durante el transporte. Cajas humedas y sellos rotos en su totalidad.
                </div>
            </div>

            <div style="background:white;border-radius:8px;padding:16px">
                <div style="font-weight:700;margin-bottom:8px;font-size:14px">Firma del encargado del almacén</div>
                <div style="display:flex;gap:12px;font-size:13px">
                    <span style="color:#555;min-width:120px">Firma encargado:</span>
                    <span style="background:#e8e8e8;border-radius:4px;padding:3px 10px;flex:1">Usuario: [Jedeermín Pérez] - Firma electrónica</span>
                </div>
            </div>

            <div class="mt-3 text-center">
                <button class="btn btn-gold" onclick="window.print()">🖨️ Imprimir</button>
                <a class="btn btn-outline" href="/Documentos/ReporteIncidentes" style="margin-left:8px">← Volver</a>
            </div>
        </div>

        <div>
            <div style="font-weight:600;margin-bottom:12px;font-size:14px">Archivos recientes</div>
            <ul class="sidebar-list">
                <li>INC 2025-0045</li>
                <li>INC 2025-0044</li>
                <li>INC 2025-0043</li>
                <li>INC 2025-0042</li>
                <li>INC 2025-0041</li>
                <li>INC 2025-0040</li>
            </ul>
        </div>
    </div>
</div>
